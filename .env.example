# ─── SimpleFIN ────────────────────────────────────────────────────────────────
#
# STEP 1: Get a setup token from https://beta-bridge.simplefin.org (one-time use)
# STEP 2: Put it here, then run:
#           python backend/scripts/claim_simplefin.py
#         The script prints your permanent access URL — paste that below.
#
# OR: Register in the app — it claims the token automatically and saves the
#     access URL encrypted in Postgres (you never need to copy it manually).
#
SIMPLEFIN_TOKEN=your_base64_setup_token_here
# After claiming, paste the FULL line the script prints (keep it secret):
# SIMPLEFIN_ACCESS_URL=https://username:password@beta-bridge.simplefin.org/simplefin

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finance:devpassword@localhost:5432/finance_tracker
DB_PASSWORD=devpassword

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth / Security ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Encryption (Fernet — for SimpleFIN access URL at rest in DB) ─────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
# All UI reads from local Postgres. SimpleFIN is manual sync only (24 req/day free tier).
BACKEND_CORS_ORIGINS=http://localhost:5173
AUTO_SYNC_ENABLED=false
SYNC_INTERVAL_HOURS=24
SIMPLEFIN_DAILY_REQUEST_LIMIT=24
TRANSFER_WINDOW_DAYS=2
# SimpleFIN Bridge: max 90 days per /accounts request; backfill uses 89-day chunks
SIMPLEFIN_CHUNK_DAYS=89
SIMPLEFIN_MAX_BACKFILL_CHUNKS=8
